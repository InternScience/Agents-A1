# Environment Configuration
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env

# =============================================================================
# Model and Inference Configuration
# =============================================================================

# Path to local model weights (for vLLM deployment mode)
MODEL_PATH=/path/to/your/model

# For remote API mode (e.g., OpenRouter), set these:
# AGENT_API_BASE_URL=https://openrouter.ai/api/v1
# MODEL_NAME=your-model-name

# Dataset path (JSONL or JSON file with "question" and "answer" fields)
DATASET=./datasets/data/gaia-2023-validation-text-103/standardized_data.jsonl

# Directory for saving inference results
OUTPUT_PATH=./results

# Inference hyperparameters
ROLLOUT_COUNT=1
TEMPERATURE=0.85
PRESENCE_PENALTY=1.1
MAX_WORKERS=16
MAX_LLM_CALL_PER_RUN=300

# =============================================================================
# External API Keys (Required)
# =============================================================================

# Serper API for web search and Google Scholar
# Get your key from: https://serper.dev/
SERPER_KEY_ID=your_serper_key

# Jina API for web page reading
# Get your key from: https://jina.ai/
JINA_API_KEYS=your_jina_key

# SandboxFusion endpoint(s) for the Python code execution tool (PythonInterpreter).
# Comma-separated list of running SandboxFusion server URLs.
# Set up a server from: https://github.com/bytedance/SandboxFusion
SANDBOX_FUSION_ENDPOINT=http://127.0.0.1:8080

# Agent inference API (OpenAI-compatible endpoint for the ReAct agent LLM)
# Only needed for remote API mode; local vLLM uses http://127.0.0.1:{port}/v1
AGENT_API_KEY=your_agent_api_key
# AGENT_API_BASE_URL=https://openrouter.ai/api/v1

# Summary model API (OpenAI-compatible endpoint for page summarization)
# This is used by the web page reader tool to summarize webpage content
SUMMARY_API_KEY=your_summary_api_key
SUMMARY_API_BASE=https://api.openai.com/v1
SUMMARY_MODEL_NAME=gpt-4o-mini

# Judge model API (OpenAI-compatible endpoint for evaluation)
# Used by evaluation/judge.py. JUDGE_MODEL_NAME is optional; when unset,
# each benchmark uses its default judge model.
JUDGE_API_KEY=your_judge_api_key
JUDGE_API_BASE=https://api.openai.com/v1
JUDGE_MODEL_NAME=

# =============================================================================
# Distributed Inference (Optional)
# =============================================================================

# Set by distributed frameworks, or manually for multi-machine splits
# WORLD_SIZE=1
# RANK=0
